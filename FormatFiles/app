  // ─── SOL PANEL: MARKDOWN + McKINSEY + EISENHOWer ─────────────────────────
  function computeStrategicData() {
    const metrics = dashboardData.EXECUTIVE_METRICS || {};
    const budget = dashboardData.BUDGET_SIMULATIONS_FORECASTS || {};
    const ratios = dashboardData.RATIO_ANALYTICS || {};
    const dupont = dashboardData.DUPONT_PILLARS || {};

    const zScore = parseFloat(metrics.altman_z_score?.value || metrics.z_score || 0);
    const cashRunway = parseFloat(metrics.cash_runway_months || metrics.cash_runway || 0);
    const healthScore = parseFloat(metrics.financial_health_score || 0);
    const roe = parseFloat(metrics.return_on_equity_pct || metrics.roe || 0);
    const netMargin = parseFloat(ratios.net_profit_margin_pct || 0);
    const currentRatio = parseFloat(ratios.current_ratio || 0);
    const debtEquity = parseFloat(ratios.debt_to_equity_ratio || 0);
    const assetTurnover = parseFloat(dupont.dupont_asset_turnover || 0);

    const stdForecast = budget.forecasted_cash_flow_standard || [];
    const stressForecast = budget.forecasted_cash_flow_recession || [];

    return { zScore, cashRunway, healthScore, roe, netMargin, currentRatio, debtEquity, assetTurnover, stdForecast, stressForecast };
  }

