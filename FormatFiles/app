    let currentLang = 'en';

    function translateStaticDOM() {
        try {
            const t = i18n[currentLang];
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (t[key]) {
                    if (key === 'legal_text') el.innerHTML = t[key];
                    else el.textContent = t[key];
                }
            });
        } catch (e) { console.error("Ceviri hatasi:", e); }
    }

    function smartTranslateToTurkish(text) {
        if (!text || currentLang === 'en') return text;
        let r = text;

        const patterns = [
            [/Our comprehensive analysis indicates that the company is currently in a (Strong|Stable|Good|Healthy|solid) financial position, with a solid foundation for future growth\./gi,
             'Kapsamli analizimiz, sirketin su anda guclu bir finansal konumda oldugunu ve gelecekteki buyume icin saglam bir temele sahip oldugunu gostermektedir.'],
            [/The DuPont breakdown reveals that ROE is driven primarily by high (Financial Leverage|leverage), rather than (Operating Efficiency|operating efficiency)\./gi,
             'DuPont ayristirmasi, ROE\'nin operasyonel verimlilikten ziyade yuksek finansal kaldiractan beslendigini ortaya koymaktadir.'],
            [/Based on our analysis, we recommend the following top three priorities:/gi,
             'Analizimize dayanarak, asagidaki uc oncelikli aksiyonu oneriyoruz:'],
            [/By addressing these key areas, we believe the company can maintain its (Strong|Healthy) financial health, drive profitability, and mitigate risks, ultimately positioning itself for long-term success\./gi,
             'Bu kilit alanlari ele alarak, sirketin guclu finansal sagligini koruyacagina, karlligi artiracagina ve riskleri azaltacagina inaniyoruz.'],
            [/stands at ([\d.]+), demonstrating/gi, 'seviyesinde olup'],
            [/ratio of ([\d.]+) suggests/gi, '$1 orani sunu gostermektedir:'],
            [/Score of ([\d.]+) \((Safe Zone|Grey Zone|Distress Zone)\), indicating low risk of bankruptcy/gi, '$1 skoru (Guvenli Bolge) - iflas riski dusuktur'],
            [/Expected ([\d.]+%) growth in (Q[1-4]) based on current sales pipeline/gi, '$1 buyume $2 ceyreginde beklenmektedir'],
            [/Projected cash runway of (\d+) months under current burn rate/gi, 'Mevcut yanma hiziyla $1 aylik nakit omru ongorulmektedir'],
            [/Potential ([\w\s]+) disruption in (Q[1-4]) due to geopolitical tensions/gi, '$2 doneminde jeopolitik gerilimler nedeniyle olasi $1 kesintisi'],
            [/Implement (Zero-based Budgeting) for (Q[1-4])/gi, '$2 icin Sifir Tabanli Butceleme uygulayin'],
            [/identify ([\d.]+%) potential savings in ([\w\s]+) spend/gi, '$2 harcamalarinda %$1 tasarruf potansiyeli tespit edin'],
            [/Develop strategies to improve slow inventory turnover and optimize asset utilization/gi, 'Yavas envanter devir hizini iyilestirmek icin stratejiler gelistirin'],
            [/Monitor geopolitical tensions and develop contingency plans to minimize the impact of potential ([\w\s]+) disruptions on ([\w\s]+) and ([\w\s]+)/gi,
             'Jeopolitik gerilimleri izleyin ve olasi $1 kesintilerinin $2 ve $3 uzerindeki etkisini en aza indirmek icin acil durum planlari gelistirin'],
            [/Our comprehensive analysis/gi, 'Kapsamli analizimiz'],
            [/indicates that/gi, 'sunu gostermektedir:'],
            [/is currently in a/gi, 'su anda'],
            [/financial position/gi, 'finansal konumdadir'],
            [/solid foundation for future growth/gi, 'gelecekteki buyume icin saglam temel'],
            [/demonstrating/gi, 'gostermektedir'],
            [/suggesting/gi, 'isaret etmektedir'],
            [/The DuPont breakdown reveals/gi, 'DuPont ayristirmasi ortaya koymaktadir'],
            [/driven primarily by/gi, 'agirlikli olarak su tarafindan yonlendirilmektedir:'],
            [/rather than/gi, 'yerine'],
            [/can improve/gi, 'iyilestirebilir'],
            [/may impact/gi, 'etkileyebilir'],
            [/impacting/gi, 'olumsuz etkilemektedir'],
            [/Based on our analysis/gi, 'Analizimize dayanarak'],
            [/we recommend/gi, 'oneriyoruz'],
            [/top three priorities/gi, 'uc oncelikli aksiyonu'],
            [/The ([\w\s]+) stands at/gi, '$1 seviyesindedir'],
            [/The ([\w\s]+) ratio/gi, '$1 orani'],
            [/Optimize ([\w\s]+) Spend/gi, '$1 Harcamasini Optimize Edin'],
            [/Address ([\w\s]+) Turnover/gi, '$1 Devir Hizini Ele Alin'],
            [/Mitigate ([\w\s]+) Risk/gi, '$1 Riskini Azaltin']
        ];

        patterns.forEach(([p, rep]) => { r = r.replace(p, rep); });

        const dict = {
            "Strong": "Guclu", "Stable": "Stabil", "Healthy": "Saglikli",
            "Excellent": "Mukemmel", "Solid": "Saglam", "Good": "IyI",
            "Current Ratio": "Cari Oran", "Quick Ratio": "Asit-Test Orani",
            "Debt-to-Equity": "Borc/Ozsermaye", "Net Profit Margin": "Net Kar Marji",
            "Return on Equity": "Ozsermaye Karlligi", "Cash Runway": "Nakit Omru",
            "Altman Z-Score": "Altman Z-Skoru", "Asset Turnover": "Varlik Devir Hizi",
            "Financial Leverage": "Finansal Kaldirac", "Operating Efficiency": "Operasyonel Verimlilik",
            "Net Margin": "Net Marj", "Safe Zone": "Guvenli Bolge",
            "Supply Chain": "Tedarik Zinciri", "Revenue": "Gelir",
            "Marketing": "Pazarlama", "Operations": "Operasyonlar",
            "Cash Flow": "Nakit Akisi", "Company": "Sirket"
        };

        const sortedWords = Object.keys(dict).sort((a, b) => b.length - a.length);
        sortedWords.forEach(en => {
            const tr = dict[en];
            const escaped = en.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            r = r.replace(new RegExp('\\b' + escaped + '\\b', 'gi'), tr);
        });

        return r;
    }

    function renderSecurityWidget() {
        try {
            const confValEl = document.getElementById('confidentiality-rate-val');
            const confDescEl = document.getElementById('confidentiality-rate-desc');
            const safeValEl = document.getElementById('confidence-rate-val');
            const safeDescEl = document.getElementById('confidence-rate-desc');

            let confText, safeText;
            if (currentLang === 'tr') {
                confText = dashboardData.confidentiality_rate_tr || "95% (Cok Gizli)";
                safeText = dashboardData.forecast_confidence_rate_tr || "88% (Dogrulanmis Veri)";
            } else {
                confText = dashboardData.confidentiality_rate_en || "95% (Highly Restricted)";
                safeText = dashboardData.forecast_confidence_rate_en || "88% (Verified Baseline)";
            }

            function parseRate(text) {
                const m = text.match(/(\d+%)/);
                return {
                    num: m ? m[1] : text.split(' ')[0],
                    detail: text.replace(m ? m[1] : '', '').replace(/^[\s\-:()]+/, '').trim()
                };
            }

            if (confValEl && confDescEl) {
                const c = parseRate(confText);
                confValEl.textContent = c.num;
                confDescEl.textContent = c.detail;
                confDescEl.title = confText;
            }
            if (safeValEl && safeDescEl) {
                const s = parseRate(safeText);
                safeValEl.textContent = s.num;
                safeDescEl.textContent = s.detail;
                safeDescEl.title = safeText;
            }
        } catch (e) { console.error("Security widget hatasi:", e); }
    }

    function renderStrategicLists() {
        try {
            function buildList(id, arr) {
                const el = document.getElementById(id);
                if (!el) return;
                const items = Array.isArray(arr) ? arr : [arr];
                el.innerHTML = '<ul style="padding-left:20px; list-style-type:disc;">' +
                    items.map(i => '<li>' + i + '</li>').join('') + '</ul>';
            }
            buildList('redFlagsContainer', dashboardData.critical_risks);
            buildList('greenFlagsContainer', dashboardData.growth_opportunities);
            buildList('actionPlanContainer', dashboardData.strategic_action_plan);
        } catch (e) { console.error("Liste hatasi:", e); }
    }

    function renderHealthScore() {
        try {
            const m = dashboardData.EXECUTIVE_METRICS || {};
            const score = m.financial_health_score || 7.8;
            if (document.getElementById('healthScoreValue'))
                document.getElementById('healthScoreValue').textContent = score;

            const circle = document.getElementById('healthScoreCircle');
            if (circle) {
                const radius = circle.r.baseVal.value;
                const circ = radius * 2 * Math.PI;
                circle.style.strokeDasharray = circ + ' ' + circ;
                circle.style.strokeDashoffset = circ - (score / 10) * circ;
            }

            const badge = document.getElementById('healthStatus');
            if (badge) {
                badge.textContent = score >= 7 ? i18n[currentLang].health_healthy : i18n[currentLang].health_critical;
                badge.style.color = score >= 7 ? '#10b981' : '#ef4444';
            }

            if (document.getElementById('zScoreValue'))
                document.getElementById('zScoreValue').textContent =
                    (m.altman_z_score ? m.altman_z_score.value : 2.85) + ' (' + (m.altman_z_score ? m.altman_z_score.zone : 'SAFE') + ')';
            if (document.getElementById('roeValue'))
                document.getElementById('roeValue').textContent = '%' + (m.return_on_equity_pct || 22.4);
            if (document.getElementById('cashRunwayValue'))
                document.getElementById('cashRunwayValue').textContent =
                    (m.cash_runway_months || 16.5) + ' ' + i18n[currentLang].months_suffix;
        } catch (e) { console.error("Health score hatasi:", e); }
    }

    function populateGrid(gridId, dataObj) {
        try {
            const grid = document.getElementById(gridId);
            if (!grid || !dataObj) return;
            grid.innerHTML = '';
            for (const [k, v] of Object.entries(dataObj)) {
                const div = document.createElement('div');
                div.className = 'metric-box';
                div.innerHTML = '<div class="num">' + v + '</div><div class="title">' +
                    k.replace(/_/g, ' ').toUpperCase() + '</div>';
                grid.appendChild(div);
            }
        } catch (e) { console.error("Grid hatasi:", e); }
    }

    function renderMarkdownNarrative() {
        try {
            const el = document.getElementById('markdownContainer');
            if (!el) return;
            if (!dashboardData.markdown_content) {
                el.innerHTML = '<p style="color:#94a3b8;">Yonetici ozeti yuklenmedi.</p>';
                return;
            }
            let text = dashboardData.markdown_content;
            if (currentLang === 'tr') text = smartTranslateToTurkish(text);
            if (typeof marked !== 'undefined') {
                el.innerHTML = marked.parse(text);
            } else {
                el.innerHTML = text
                    .replace(/\n/g, '<br>')
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/^# (.*)$/gm, '<h3>$1</h3>');
            }
        } catch (e) { console.error("Markdown hatasi:", e); }
    }

    function renderChart() {
        try {
            const ctx = document.getElementById('cashFlowChart');
            if (!ctx) return;
            const budgets = dashboardData.BUDGET_SIMULATIONS_FORECASTS || {};
            const std = budgets.forecasted_cash_flow_standard || [0];
            const rec = budgets.forecasted_cash_flow_recession || [0];
            if (window.myChart) window.myChart.destroy();
            window.myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Array.from({length: std.length}, (_, i) =>
                        currentLang === 'tr' ? (i+1) + '. Ay' : 'Month ' + (i+1)),
                    datasets: [
                        { label: i18n[currentLang].chart_standard, data: std, borderColor: '#10b981', fill: false },
                        { label: i18n[currentLang].chart_stress, data: rec, borderColor: '#ef4444', fill: false }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        } catch (e) { console.error("Grafik hatasi:", e); }
    }

    function runUiPipeline() {
        console.log("UI Pipeline baslatiliyor...");
        translateStaticDOM();
        renderSecurityWidget();
        renderHealthScore();
        populateGrid('ratioAnalyticsGrid', dashboardData.RATIO_ANALYTICS);
        populateGrid('dupontGrid', dashboardData.DUPONT_PILLARS);
        populateGrid('savingsGrid', dashboardData.BUDGET_SIMULATIONS_FORECASTS ? dashboardData.BUDGET_SIMULATIONS_FORECASTS.cost_cutting_savings : null);
        renderStrategicLists();
        renderMarkdownNarrative();
        renderChart();
        console.log("UI Pipeline tamamlandi");
    }

    const langToggle = document.getElementById('langToggle');
    if (langToggle) {
        langToggle.addEventListener('click', () => {
            currentLang = currentLang === 'en' ? 'tr' : 'en';
            langToggle.textContent = i18n[currentLang].langBtn;
            runUiPipeline();
        });
    }

    runUiPipeline();
});
