document.addEventListener('DOMContentLoaded', () => {
    // Check if dashboardData is available (generated by Python script)
    if (typeof dashboardData === 'undefined') {
        console.error("Dashboard data not found! Ensure python ceo_agent.py has been run.");
        return;
    }

    const i18n = {
        en: {
            title: "Executive Summary Dashboard",
            subtitle: "Real-time consolidated financial insights.",
            exec_summary: "Executive Summary (CEO & CFO Perspective)",
            financial_health: "Financial Health",
            z_score: "Altman Z-Score",
            cash_runway: "Cash Runway",
            roe: "Return on Equity",
            ratio_dupont: "Ratio Analytics & DuPont Pillars",
            ratio_title: "Ratio Analytics",
            dupont_title: "DuPont Pillars",
            budget_sim: "Budget Simulations & Forecasts",
            cost_cutting: "Cost Cutting Savings Plans",
            strategic_action: "Strategic Action Plan",
            opportunities: "Opportunities & Growth",
            risks: "Critical Risks",
            langBtn: "🇹🇷 TR",
            health_evaluating: "Evaluating...",
            health_healthy: "Healthy",
            health_monitor: "Monitor",
            health_critical: "Critical",
            chart_standard: "Standard Forecast",
            chart_stress: "Recession Stress-Test"
        },
        tr: {
            title: "Yönetici Özeti Panosu",
            subtitle: "Gerçek zamanlı konsolide finansal öngörüler.",
            exec_summary: "Yönetici Özeti (CEO & CFO Perspektifi)",
            financial_health: "Finansal Sağlık",
            z_score: "Altman Z-Skoru",
            cash_runway: "Nakit Bitiş Süresi",
            roe: "Özkaynak Kârlılığı",
            ratio_dupont: "Rasyo Analizleri & DuPont Sütunları",
            ratio_title: "Rasyo Analizleri",
            dupont_title: "DuPont Sütunları",
            budget_sim: "Bütçe Simülasyonları ve Tahminler",
            cost_cutting: "Maliyet Düşürme Tasarruf Planları",
            strategic_action: "Stratejik Aksiyon Planı",
            opportunities: "Fırsatlar ve Büyüme",
            risks: "Kritik Riskler",
            langBtn: "🇬🇧 EN",
            health_evaluating: "Değerlendiriliyor...",
            health_healthy: "Sağlıklı",
            health_monitor: "İzlenmeli",
            health_critical: "Kritik",
            chart_standard: "Standart Tahmin",
            chart_stress: "Resesyon Stres Testi"
        }
    };

    let currentLang = 'en';

    const execMetrics = dashboardData.EXECUTIVE_METRICS || {};
    const ratioAnalytics = dashboardData.RATIO_ANALYTICS || {};
    const dupontPillars = dashboardData.DUPONT_PILLARS || {};
    const budgets = dashboardData.BUDGET_SIMULATIONS_FORECASTS || {};

    // --- Populate Executive Metrics ---
    const scoreValue = execMetrics.financial_health_score || 0;
    document.getElementById('healthScoreValue').textContent = scoreValue;
    
    // Animate Circle
    const circle = document.getElementById('healthScoreCircle');
    if (circle) {
        const radius = circle.r.baseVal.value;
        const circumference = radius * 2 * Math.PI;
        circle.style.strokeDasharray = `${circumference} ${circumference}`;
        circle.style.strokeDashoffset = circumference;

        const offset = circumference - (scoreValue / 10) * circumference;
        
        setTimeout(() => {
            circle.style.strokeDashoffset = offset;
            
            if(scoreValue < 5) {
                circle.style.stroke = '#ef4444'; // Red
                document.getElementById('healthStatus').style.color = '#ef4444';
                document.getElementById('healthStatus').style.background = 'rgba(239, 68, 68, 0.1)';
            } else if(scoreValue < 7.5) {
                circle.style.stroke = '#f59e0b'; // Yellow
                document.getElementById('healthStatus').style.color = '#f59e0b';
                document.getElementById('healthStatus').style.background = 'rgba(245, 158, 11, 0.1)';
            }
        }, 100);
    }

    function updateHealthStatusText() {
        const t = i18n[currentLang];
        document.getElementById('healthStatus').textContent = scoreValue > 7.5 ? t.health_healthy : (scoreValue > 5 ? t.health_monitor : t.health_critical);
    }
    updateHealthStatusText();

    const zScore = execMetrics.altman_z_score || {};
    document.getElementById('zScoreValue').textContent = `${zScore.value || '--'} (${zScore.zone || 'Unknown'})`;
    document.getElementById('cashRunwayValue').textContent = `${execMetrics.cash_runway_months || '--'} Months`; // "Months" could be translated, keeping simple for now
    document.getElementById('roeValue').textContent = `${execMetrics.return_on_equity_pct || '--'}%`;

    // --- Helper function to populate grids ---
    function populateGrid(gridId, dataObj) {
        const grid = document.getElementById(gridId);
        if (!grid || !dataObj) return;
        grid.innerHTML = ''; 
        for (const [key, value] of Object.entries(dataObj)) {
            const div = document.createElement('div');
            div.style.background = 'rgba(255,255,255,0.05)';
            div.style.padding = '1rem';
            div.style.borderRadius = '10px';
            div.style.border = '1px solid rgba(255,255,255,0.1)';
            div.style.display = 'flex';
            div.style.flexDirection = 'column';
            
            const label = document.createElement('span');
            // Format key: replace underscores with spaces and capitalize
            label.textContent = key.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            label.style.fontSize = '0.80rem';
            label.style.color = 'var(--text-secondary)';
            label.style.marginBottom = '0.5rem';
            
            const val = document.createElement('span');
            val.textContent = typeof value === 'number' && key.includes('pct') ? `${value}%` : value;
            if(typeof value === 'number' && !key.includes('pct') && value > 1000) {
                // simple currency formatting for big numbers
                val.textContent = '$' + value.toLocaleString();
            }
            val.style.fontSize = '1.2rem';
            val.style.fontWeight = '700';
            val.style.color = 'var(--text-primary)';
            
            div.appendChild(label);
            div.appendChild(val);
            grid.appendChild(div);
        }
    }

    // --- Populate Grids ---
    populateGrid('ratioAnalyticsGrid', ratioAnalytics);
    populateGrid('dupontGrid', dupontPillars);
    populateGrid('savingsGrid', budgets.cost_cutting_savings);

    // --- Populate Narrative Lists ---
    function populateList(listId, arrayData) {
        const list = document.getElementById(listId);
        if(!list || !arrayData) return;
        list.innerHTML = '';
        if(arrayData.length === 0) list.innerHTML = "<li>None identified.</li>";
        arrayData.forEach(item => {
            const li = document.createElement('li');
            li.textContent = item;
            list.appendChild(li);
        });
    }

    function renderDynamicText() {
        const narrativeSource = currentLang === 'tr' && dashboardData.STRATEGIC_NARRATIVE_TR ? dashboardData.STRATEGIC_NARRATIVE_TR : (dashboardData.STRATEGIC_NARRATIVE || {});
        populateList('redFlagsList', narrativeSource.red_flags);
        populateList('greenFlagsList', narrativeSource.green_flags);
        populateList('actionPlanList', narrativeSource.action_plan);

        // --- Render Markdown Executive Summary ---
        const markdownContainer = document.getElementById('markdownContainer');
        const mdSource = currentLang === 'tr' && dashboardData.markdown_content_tr ? dashboardData.markdown_content_tr : dashboardData.markdown_content;
        if (markdownContainer && mdSource) {
            markdownContainer.innerHTML = marked.parse(mdSource);
        }
    }
    renderDynamicText();

    // --- Chart.js Integration ---
    const ctx = document.getElementById('cashFlowChart');
    if (ctx && budgets.forecasted_cash_flow_standard) {
        // Create labels Month 1 to 12
        const labels = Array.from({length: 12}, (_, i) => `Month ${i+1}`);
        
        window.myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: i18n[currentLang].chart_standard,
                        data: budgets.forecasted_cash_flow_standard,
                        borderColor: '#3b82f6', // blue
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        borderWidth: 2,
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: i18n[currentLang].chart_stress,
                        data: budgets.forecasted_cash_flow_recession,
                        borderColor: '#ef4444', // red
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                color: '#94a3b8',
                scales: {
                    x: {
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { color: '#94a3b8' }
                    },
                    y: {
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { 
                            color: '#94a3b8',
                            callback: function(value) { return '$' + value.toLocaleString(); }
                        }
                    }
                },
                plugins: {
                    legend: { labels: { color: '#f8fafc' } }
                }
            }
        });
    }

    // --- Theme Toggle ---
    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const currentTheme = document.body.getAttribute('data-theme') || 'dark';
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            document.body.setAttribute('data-theme', newTheme);
            
            // Update Chart Colors
            if (window.myChart) {
                const textColor = newTheme === 'light' ? '#475569' : '#94a3b8';
                const gridColor = newTheme === 'light' ? 'rgba(0,0,0,0.1)' : 'rgba(255,255,255,0.05)';
                const legendColor = newTheme === 'light' ? '#0f172a' : '#f8fafc';
                
                window.myChart.options.color = textColor;
                window.myChart.options.scales.x.grid.color = gridColor;
                window.myChart.options.scales.x.ticks.color = textColor;
                window.myChart.options.scales.y.grid.color = gridColor;
                window.myChart.options.scales.y.ticks.color = textColor;
                window.myChart.options.plugins.legend.labels.color = legendColor;
                window.myChart.update();
            }
        });
    }

    // --- Language Toggle ---
    const langToggle = document.getElementById('langToggle');
    if (langToggle) {
        langToggle.addEventListener('click', () => {
            currentLang = currentLang === 'en' ? 'tr' : 'en';
            
            // Update static translations
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18n[currentLang][key]) {
                    el.textContent = i18n[currentLang][key];
                }
            });

            // Update Health text
            updateHealthStatusText();

            // Update Dynamic text (lists and markdown)
            renderDynamicText();

            // Update Button
            langToggle.textContent = i18n[currentLang].langBtn;

            // Update Chart labels
            if (window.myChart) {
                window.myChart.data.datasets[0].label = i18n[currentLang].chart_standard;
                window.myChart.data.datasets[1].label = i18n[currentLang].chart_stress;
                window.myChart.update();
            }
        });
    }
});
