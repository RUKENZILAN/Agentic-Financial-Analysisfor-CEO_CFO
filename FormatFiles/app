  // ─── COMPANY DROPDOWN ──────────────────────────────────────────────────────
  function renderCompanyDropdown() {
    const sel = document.getElementById('companySelect');
    if (!sel) return;
    const companies = dashboardData.companies_list || [];
    if (!companies || companies.length === 0) {
      sel.parentElement && (sel.parentElement.style.display = 'none');
      return;
    }
    sel.innerHTML = '';
    companies.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c.code || c.id || c.value || c;
      opt.textContent = c.name || c.label || c.code || c;
      if ((c.code || c) === dashboardData.company_code) opt.selected = true;
      sel.appendChild(opt);
    });
    sel.addEventListener('change', () => {
      // Şirket değiştirildiğinde sayfa yenileniyor (ceo_agent.py yeniden çalıştırılmalı)
      console.log('Şirket seçildi:', sel.value);
