  function buildEisenhowerMatrix(d, isTr) {
    const matrix = { do: [], schedule: [], delegate: [], eliminate: [] };

    if (isTr) {
      // DO - Acil & Önemli
      if (d.cashRunway > 0 && d.cashRunway < 6)
        matrix.do.push(`Nakit krizini çöz — Ömür ${d.cashRunway} ay!`);
      if (d.zScore > 0 && d.zScore < 1.8)
        matrix.do.push(`Z-Skoru (${d.zScore}) iflas bölgesi — Yeniden yapılanma başlat`);
      if (d.currentRatio > 0 && d.currentRatio < 1)
        matrix.do.push('Cari oran kritik seviyede — Kısa vadeli borçları yeniden yapılandır');
      if (d.zScore >= 1.8 && d.cashRunway >= 6)
        matrix.do.push(`Mevcut finansal sağlık skorunu (${d.healthScore}/10) koru`);

      // SCHEDULE - Önemli & Acil Değil
      if (d.roe > 0 && d.roe < 15)
        matrix.schedule.push(`ROE'yi %${d.roe}'dan %${Math.round(d.roe * 1.3)}'a taşı`);
      matrix.schedule.push('Sıfır tabanlı bütçeleme (ZBB) geçişini planla');
      if (d.assetTurnover < 1)
        matrix.schedule.push(`Varlık devir hızını (${d.assetTurnover}x) optimize et`);
      matrix.schedule.push('Dijital altyapı yatırım takvimini hazırla');

      // DELEGATE - Acil & Önemli Değil
      matrix.delegate.push('Rutin rasyo raporlamalarını analiz ekibine devret');
      matrix.delegate.push('Yazılım lisans denetimini BT birimine aktar');
      if (d.debtEquity < 0.3)
        matrix.delegate.push('Düşük riskli borç yönetimini finans direktörüne devret');

      // ELIMINATE - Acil Değil & Önemli Değil
      matrix.eliminate.push('Verimsiz reklam kanallarındaki bütçeleri durdur');
      matrix.eliminate.push('Atıl yazılım aboneliklerini iptal et');
      matrix.eliminate.push('Manuel veri giriş süreçlerini kaldır');
    } else {
      // DO
      if (d.cashRunway > 0 && d.cashRunway < 6)
        matrix.do.push(`Fix cash flow — Runway is ${d.cashRunway} months!`);
      if (d.zScore > 0 && d.zScore < 1.8)
        matrix.do.push(`Z-Score (${d.zScore}) in distress — Initiate restructuring now`);
      if (d.currentRatio > 0 && d.currentRatio < 1)
        matrix.do.push('Current ratio critical — Restructure short-term debt');
      if (d.zScore >= 1.8 && d.cashRunway >= 6)
        matrix.do.push(`Maintain financial health score at ${d.healthScore}/10`);

      // SCHEDULE
      if (d.roe > 0 && d.roe < 15)
        matrix.schedule.push(`Build ROE from ${d.roe}% to ${Math.round(d.roe * 1.3)}%`);
      matrix.schedule.push('Plan Zero-Based Budgeting (ZBB) transition');
      if (d.assetTurnover < 1)
        matrix.schedule.push(`Optimize asset turnover (currently ${d.assetTurnover}x)`);
      matrix.schedule.push('Prepare digital infrastructure investment roadmap');

      // DELEGATE
      matrix.delegate.push('Delegate routine ratio reporting to analyst team');
      matrix.delegate.push('Transfer software license audit to IT department');
      if (d.debtEquity < 0.3)
        matrix.delegate.push('Assign low-risk debt management to CFO office');

      // ELIMINATE
      matrix.eliminate.push('Stop spend on underperforming ad channels');
      matrix.eliminate.push('Cancel redundant software subscriptions');
      matrix.eliminate.push('Remove manual data entry workflows');
    }

    return matrix;
  }

  // ─── MARKDOWN NARRATIVE ───────────────────────────────────────────────────
  // Backend hem TR hem EN üretir: markdown_content (TR) + markdown_content_en (EN)
  function renderMarkdownContent(content) {
    const container = document.getElementById('markdownContainer');
    if (!container) return;
    try {
      container.innerHTML = (typeof marked !== 'undefined' && typeof marked.parse === 'function')
        ? marked.parse(content)
        : content.replace(/\n/g, '<br>');
    } catch (e) {
      container.innerHTML = content.replace(/\n/g, '<br>');
    }
  }

  function renderMarkdownNarrative() {
    const container = document.getElementById('markdownContainer');
    if (!container) return;

    const trContent = dashboardData.markdown_content || '';
    const enContent = dashboardData.markdown_content_en || trContent;

    const content = currentLang === 'tr' ? trContent : enContent;

    if (!content) {
      container.innerHTML = `<p style="text-align:center;padding:1rem;color:var(--text-3)">${i18n[currentLang].no_data}</p>`;
      return;
    }
    renderMarkdownContent(content);
  }

  // ─── SAĞ PANEL BİLEŞENLERİ ────────────────────────────────────────────────
  function renderHealthScore() {
    const metrics = dashboardData.EXECUTIVE_METRICS || {};
    const scoreValue = metrics.financial_health_score || 0;

    const scoreEl = document.getElementById('healthScoreValue');
    if (scoreEl) scoreEl.textContent = scoreValue;

    const circle = document.getElementById('healthScoreCircle');
    if (circle) {
      const circ = 2 * Math.PI * 15.9155;
      circle.style.strokeDasharray = `${circ} ${circ}`;
      circle.style.strokeDashoffset = circ - (scoreValue / 10) * circ;
    }

    const statusBadge = document.getElementById('healthStatus');
    if (statusBadge) {
      const healthy = scoreValue >= 7;
      statusBadge.textContent = healthy ? i18n[currentLang].health_healthy : i18n[currentLang].health_critical;
      statusBadge.className = `health-badge ${healthy ? 'healthy' : 'critical'}`;
    }

    const zScoreEl = document.getElementById('zScoreValue');
    if (zScoreEl)
      zScoreEl.textContent = `${metrics.altman_z_score?.value || 0} (${metrics.altman_z_score?.zone || 'N/A'})`;

    const roeEl = document.getElementById('roeValue');
    if (roeEl) roeEl.textContent = `${metrics.return_on_equity_pct || 0}%`;

    const cashEl = document.getElementById('cashRunwayValue');
    if (cashEl) cashEl.textContent = `${metrics.cash_runway_months || 0}${i18n[currentLang].months_suffix}`;
  }

  function populateGrid(gridId, dataObj) {
    const grid = document.getElementById(gridId);
    if (!grid || !dataObj) return;
    grid.innerHTML = '';
    for (const [key, value] of Object.entries(dataObj)) {
      const div = document.createElement('div');
      div.className = 'metric-box';
      div.innerHTML = `
        <div class="metric-val">${value}</div>
        <div class="metric-key">${key.replace(/_/g, ' ')}</div>`;
      grid.appendChild(div);
    }
  }

  function renderStrategicLists() {
    const buildList = (id, arr) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.innerHTML = `<ul>${(arr && arr.length ? arr : [i18n[currentLang].no_data]).map(item => `<li>${item}</li>`).join('')}</ul>`;
    };
    buildList('redFlagsContainer', dashboardData.critical_risks);
    buildList('greenFlagsContainer', dashboardData.growth_opportunities);
    buildList('actionPlanContainer', dashboardData.strategic_action_plan);
  }

