    const safeVal = document.getElementById('confidence-rate-val');
    if (confVal) confVal.textContent = currentLang === 'tr' ? dashboardData.confidentiality_rate_tr : dashboardData.confidentiality_rate_en;
    if (safeVal) safeVal.textContent = currentLang === 'tr' ? dashboardData.forecast_confidence_rate_tr : dashboardData.forecast_confidence_rate_en;
  }

  function renderChart() {
    const ctx = document.getElementById('cashFlowChart');
    if (!ctx) return;
    const b = dashboardData.BUDGET_SIMULATIONS_FORECASTS || {};
    const std = b.forecasted_cash_flow_standard || [];
    const rec = b.forecasted_cash_flow_recession || [];
    if (window.myChart) window.myChart.destroy();
    window.myChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: Array.from({ length: std.length || 12 }, (_, i) =>
          currentLang === 'tr' ? `${i + 1}. Ay` : `Month ${i + 1}`),
        datasets: [
          { label: i18n[currentLang].chart_standard, data: std, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.08)', fill: true, tension: 0.3 },
          { label: i18n[currentLang].chart_stress, data: rec, borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.08)', fill: true, tension: 0.3 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 } } } },
        scales: {
          x: { ticks: { color: '#64748b' }, grid: { color: '#1e293b' } },
          y: { ticks: { color: '#64748b' }, grid: { color: '#1e293b' } }
        }
      }
    });
  }

  function renderHistoricalChart() {
    const ctx = document.getElementById('historicalChart');
    if (!ctx) return;
    const hc = dashboardData.historical_comparison;
    if (!hc || !hc.labels || !hc.health_history || !hc.roe_history) return;
    const minLen = Math.min(hc.labels.length, hc.health_history.length, hc.roe_history.length);
    if (minLen < 2) return;
    if (window.historicalChartInstance) window.historicalChartInstance.destroy();
    window.historicalChartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: hc.labels.slice(0, minLen),
        datasets: [
          { label: currentLang === 'tr' ? 'Finansal Sağlık Skoru' : 'Financial Health Score', data: hc.health_history.slice(0, minLen), borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.1)', fill: true, tension: 0.3, yAxisID: 'y' },
          { label: 'ROE %', data: hc.roe_history.slice(0, minLen), borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.1)', fill: true, tension: 0.3, yAxisID: 'y1' }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { color: '#94a3b8', font: { size: 11 } } } },
        scales: {
          y: { type: 'linear', position: 'left', ticks: { color: '#64748b' }, grid: { color: '#1e293b' } },
          y1: { type: 'linear', position: 'right', ticks: { color: '#64748b' }, grid: { drawOnChartArea: false } }
        }
      }
    });
  }

  // ─── TEMA ─────────────────────────────────────────────────────────────────
  const themeToggle = document.getElementById('themeToggle');
  let storedTheme = null;
  try { storedTheme = localStorage.getItem('theme'); } catch (e) {}
  if (storedTheme === 'bw') document.body.classList.add('theme-bw');

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isBw = document.body.classList.toggle('theme-bw');
      try { localStorage.setItem('theme', isBw ? 'bw' : 'default'); } catch (e) {}
      const icon = document.getElementById('themeToggleIcon');
      const txt = document.getElementById('themeToggleText');
      if (icon) icon.textContent = isBw ? '🌈' : '⚫';
      if (txt) txt.textContent = isBw ? (currentLang === 'tr' ? 'Renkli Mod' : 'Color Mode') : (currentLang === 'tr' ? 'Siyah-Beyaz' : 'Black & White');
    });
  }

  // ─── PDF ──────────────────────────────────────────────────────────────────
  window.exportToPDF = () => window.print();

  // ─── DİL DEĞİŞTİRİCİ ─────────────────────────────────────────────────────
  const langToggle = document.getElementById('langToggle');
  if (langToggle) {
    langToggle.addEventListener('click', () => {
      currentLang = currentLang === 'en' ? 'tr' : 'en';
      langToggle.textContent = i18n[currentLang].langBtn;
      runUiPipeline();
    });
  }

  // ─── PIPELINE ─────────────────────────────────────────────────────────────
  function runUiPipeline() {
    translateStaticDOM();
    renderSecurityWidget();
    renderHealthScore();
    renderLeftPanel();
    renderStrategicLists();
    populateGrid('ratioAnalyticsGrid', dashboardData.RATIO_ANALYTICS);
    populateGrid('dupontGrid', dashboardData.DUPONT_PILLARS);
    populateGrid('savingsGrid', dashboardData.BUDGET_SIMULATIONS_FORECASTS?.cost_cutting_savings || null);
    renderChart();
    renderHistoricalChart();
  }

  runUiPipeline();
});
