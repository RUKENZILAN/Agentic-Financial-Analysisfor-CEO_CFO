import logging
# Ortak kural setimizi içeri aktarıyoruz
from base_agent import BaseAgent

class OptimizerAgent(BaseAgent):
    """
    Role: Financial Optimizer Agent
    Bu sınıf BaseAgent şablonundan türetilmiştir ve kurallara tam uyar.
    """
    def __init__(self):
        # Üst sınıfa (BaseAgent) ajanın adını ve kalıcı sistem promptunu gönderiyoruz
        super().__init__(
            name="Optimizer Agent",
            system_prompt="""Context: You are the Optimizer Agent within the Antigravity Multi-Agent system. Your job is to identify cost-saving opportunities and resource allocation improvements based on the financial data provided by the CEO Agent.

Instructions:
1. Review the structured financial data, particularly expense accounts and resource allocation.
2. Identify areas of operational inefficiency or bloated expenses.
3. Propose actionable cost-saving strategies and optimization techniques.
4. Prepare an optimization report detailing your suggestions.
5. Return your findings to the Central Memory for the CEO Agent to consolidate.
"""
        )

    def process(self, memory):
        # BaseAgent'tan gelen standart başlangıç logunu tetikliyoruz
        self.log_start(memory)
        
        # Gerçek senaryoda Excel verisi buradan okunabilir:
        # structured_data = memory.get("structured_data")
        
        # Hafızadaki mevcut alt ajan bulgularını alıyoruz
        findings = memory.get("sub_agent_findings", {})
        
        # Kendi analiz sonuçlarımızı ekliyoruz
        findings[self.name] = {
            "Cost Savings": "Identified 15% potential savings in marketing spend.",
            "Inefficiencies": "Software subscription redundancies costing $12k annually.",
            "Resource Allocation": "Recommend shifting budget from legacy IT to cloud infrastructure.",
            "Optimization Strategy": "Implement zero-based budgeting for Q4."
        }
        
        # Güncellenmiş listeyi merkezi hafızaya geri yazıyoruz
        memory.set("sub_agent_findings", findings)
        
        # BaseAgent'tan gelen standart bitiş logunu tetikliyoruz
        self.log_end(memory)

if __name__ == "__main__":
    from ceo_agent import CentralMemory
    logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(name)s - %(levelname)s - %(message)s')
    
    # Test ortamı
    memory = CentralMemory()
    memory.set("structured_data", {"mock": "data"})
    
    agent = OptimizerAgent()
    agent.process(memory)
    
    print("\nHafızaya Kaydedilen Bulgular:")
    print(memory.get("sub_agent_findings"))
