import logging
# Oluşturduğumuz şablonu içeri aktarıyoruz
from base_agent import BaseAgent

class AnalystAgent(BaseAgent):
    """
    Role: Financial Analyst Agent
    """
    def __init__(self):
        # Üst sınıfa (BaseAgent) ajanın adını ve promptunu gönderiyoruz
        super().__init__(
            name="Analyst Agent",
            system_prompt=(
                "Context: You are the Financial Analyst Agent...\n"
                "Instructions:\n1. Calculate key financial ratios..."
            )
        )

    def process(self, memory):
        # BaseAgent içindeki ortak log fonksiyonunu çağırıyoruz
        self.log_start(memory)
        
        # 🎯 GERÇEK ANALİZ MANTIĞI BURAYA GELECEK
        # Örn: structured_data = memory.get("structured_data")
        
        # Hafızadaki mevcut bulguları al ve güncelle
        findings = memory.get("sub_agent_findings", {})
        findings[self.name] = {
            "Liquidity": "Strong, Current Ratio at 2.5",
            "Solvency": "Stable, Debt-to-Equity at 0.4",
            "Profitability": "Improving, Net Margin up by 2%",
            "Anomalies": "Unusual spike in administrative expenses in Q3"
        }
        memory.set("sub_agent_findings", findings)
        
        # Standart bitiş logunu çağırıyoruz
        self.log_end(memory)

if __name__ == "__main__":
    from ceo_agent import CentralMemory
    logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
    
    memory = CentralMemory()
    agent = AnalystAgent()
    agent.process(memory)
