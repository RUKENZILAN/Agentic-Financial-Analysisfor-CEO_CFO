            "critical_risks": ["Tedarik zincirinde jeopolitik riskler (S4)", "Maliyetlerde enflasyonist baskı"],
            "growth_opportunities": ["Pazarlama harcamalarında %15 tasarruf imkanı", "Bulut altyapısına geçiş"],
            "strategic_action_plan": ["Sıfır tabanlı bütçelemeye geçiş yapılması", "Atıl yazılım aboneliklerinin iptali"],

            "EXECUTIVE_METRICS": {
                "financial_health_score": 7.8,
                "altman_z_score": {"value": 2.85, "zone": "SAFE"},
                "cash_runway_months": 16.5,
                "return_on_equity_pct": 22.4
            },
            "RATIO_ANALYTICS": {
                "current_ratio": 2.15,
                "quick_ratio": 1.45,
                "debt_to_equity_ratio": 0.55,
                "net_profit_margin_pct": 14.2
            },
            "DUPONT_PILLARS": {
                "dupont_net_profit_margin": 0.142,
                "dupont_asset_turnover": 0.85,
                "dupont_equity_multiplier": 1.85
            },
            "BUDGET_SIMULATIONS_FORECASTS": {
                "forecasted_cash_flow_standard": [120000, 125000, 130000, 128000, 135000, 140000, 145000, 150000, 155000, 160000, 165000, 170000],
                "forecasted_cash_flow_recession": [120000, 115000, 110000, 105000, 100000, 95000, 90000, 88000, 85000, 83000, 80000, 78000],
                "cost_cutting_savings": {
                    "marketing_spend_reduction": "$15,000",
                    "software_redundancy_cleanup": "$12,000",
                    "cloud_infrastructure_migration": "Optimize Edildi"
                }
            },
            "historical_comparison": {
                "has_comparison": len(history_list) > 1,
                "labels": [h["label"] for h in history_list] if history_list else ["Q1", "Q2", "Q3", "Q4"],
                "health_history": [h["health"] for h in history_list] if history_list else [6.5, 6.7, 6.9, 7.8],
                "roe_history": [h["roe"] for h in history_list] if history_list else [18, 19, 20, 22.4]
            }
        }

        # dashboard_data.js dosyasını yaz
        output_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "dashboard_data.js")
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(f"const dashboardData = {json.dumps(final_js_object, indent=2, ensure_ascii=False)};")

        self.company_manager.update_last_report(company_code)
        logging.info("[CEO Agent] dashboard_data.js başarıyla güncellendi, veriler ön yüze bağlandı!")
        self.generate_pdf_report(company_code, final_js_object)

if __name__ == "__main__":
    memory = CentralMemory()
    sub_agents = [AnalystAgent(), AuditorAgent(), OptimizerAgent(), ForecasterRiskAgent(), DuPontAgent()]
    ceo = CEOAgent(memory, sub_agents)
    ceo.run(args.company)
