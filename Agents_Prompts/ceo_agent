import logging

# Configure basic logging
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(name)s - %(levelname)s - %(message)s')
logger = logging.getLogger('CEOAgent')

class CentralMemory:
    """
    Central Memory for the Financial Multi-Agent System.
    """
    def __init__(self):
        self.data = {
            "financial_files": {},
            "structured_data": {},
            "sub_agent_findings": {},
            "executive_summary": None,
            "logs": []
        }

    def set(self, key, value):
        self.data[key] = value

    def get(self, key, default=None):
        return self.data.get(key, default)
        
    def add_log(self, message):
        self.data["logs"].append(message)
        logger.info(message)


class CEOAgent:
    """
    Role: Financial Operations Orchestrator (CEO Agent)
    """
    SYSTEM_PROMPT = """# ROLE AND CONTEXT
You are a top-tier AI consultant and financial analyst supporting a company founder/CEO. Your communication style must be diplomatic, moderate, and constructive (avoid overly sharp or aggressive language). Provide balanced insights, focusing on collaboration and thoughtful decision-making.

# ANALYSIS AND FORMAT STANDARDS
When asked to evaluate a company's monthly balance sheet and financial status, you must present the analysis by clearly separating the perspectives of the CFO and the CEO, and by providing scenario analyses:

1. SEPARATION OF PERSPECTIVES (CFO vs. CEO):
   Present the analysis with two distinct sections:
   - CFO PERSPECTIVE: Focus on financial risk management, capital preservation, liquidity, CapEx constraints, and debt structure.
   - CEO PERSPECTIVE: Focus on market leadership, strategic direction, organizational agility, growth opportunities, and competition.

2. SCENARIO ANALYSIS:
   For both perspectives, you must explicitly outline:
   - Best-Case Scenario: Optimal outcomes if strategies succeed.
   - Worst-Case Scenario: Potential risks and downsides if negative trends materialize.

3. MCKINSEY FORMAT:
   Structure the core evaluation across these 3 strategic horizons:
   - Horizon 1: Defend and optimize core business/operations.
   - Horizon 2: High-potential growth areas, new markets, and accelerating innovation.
   - Horizon 3: Future options, radical transformation, and building the future.

4. EISENHOWER MATRIX:
   List the consolidated priorities in a 2x2 clear Markdown table formatted as (1. Do First, 2. Schedule, 3. Delegate, 4. Eliminate).

5. MONTHLY BALANCE SHEET CONTROL PARAMETERS:
   Explicitly include the following balance sheet items:
   - Liquidity and Working Capital (Current Ratio, Quick Ratio, Cash Conversion Cycle).
   - Asset Structure and Quality (Cash ratio, doubtful receivables, inventory aging, CapEx tracking).
   - Liability Structure and Debt (Short-term debt balance, leverage ratio, FX position and currency risk).

# LANGUAGE AND WRITING RULES
- Use clear, understandable, and diplomatic English.
- Maintain a polite, supportive, and balanced tone.
- Avoid absolute certainty; use framing like "it might be beneficial to consider," "we could potentially face," etc.
- Always conclude the analysis with a collaborative "Executive Summary and Next Steps" section that bridges the CFO and CEO viewpoints.
"""

    def __init__(self, memory: CentralMemory, sub_agents: dict = None):
        self.name = "CEO Agent"
        self.memory = memory
        self.sub_agents = sub_agents or {}

    def start_workflow(self, financial_files: list):
        import pandas as pd
        self.memory.add_log(f"[{self.name}] Workflow started with {len(financial_files)} financial files.")
        
        # 1. Validate and structure incoming raw financial data
        self.memory.add_log(f"[{self.name}] Validating and structuring incoming raw financial data...")
        
        structured_data = {}
        for file_path in financial_files:
            if file_path.endswith(('.xlsx', '.xls')):
                try:
                    self.memory.add_log(f"[{self.name}] Reading Excel file: {file_path}")
                    # Read all sheets
                    xls = pd.read_excel(file_path, sheet_name=None)
                    parsed_file = {}
                    for sheet_name, df in xls.items():
                        # Convert to dict, taking first 10 rows to avoid blowing up memory during this test
                        parsed_file[sheet_name] = df.head(10).to_dict(orient='records')
                    structured_data[file_path] = parsed_file
                except Exception as e:
                    self.memory.add_log(f"[{self.name}] ERROR reading {file_path}: {e}")
            else:
                self.memory.add_log(f"[{self.name}] WARNING: Unsupported file type: {file_path}")
                
        self.memory.set("structured_data", structured_data)
        
        # 2. Parallel-dispatch the relevant datasets
        self.memory.add_log(f"[{self.name}] Dispatching datasets to sub-agents: {list(self.sub_agents.keys())}")
        for agent_name, agent_instance in self.sub_agents.items():
            if agent_name != "ui_ux_agent":
                self.memory.add_log(f"[{self.name}] Triggering {agent_name}...")
                agent_instance.process(self.memory)

        # 3. Consolidate all technical findings
        self.memory.add_log(f"[{self.name}] Consolidating technical findings from sub-agents...")
        
        # 4. Generate Executive Summary
        self.memory.add_log(f"[{self.name}] Generating Executive Summary & Strategic Action Plan...")
        
        mock_markdown = """### 1. Perspectives and Scenarios

#### CFO Perspective
From a financial standpoint, our liquidity appears stable with a current ratio of 2.15. However, it might be prudent to monitor the recent 15-day increase in Days Sales Outstanding (DSO), which currently ties up $12M in cash.
*   **Best-Case Scenario:** Improved collection protocols smoothly recover the $12M, providing a comfortable buffer for upcoming short-term debt maturities without external financing.
*   **Worst-Case Scenario:** Prolonged collection delays combined with upcoming debt obligations ($5M) could create a temporary liquidity squeeze, necessitating higher-interest short-term borrowing.

#### CEO Perspective
Strategically, our 22% growth momentum in the European market represents a highly promising opportunity. We should consider reallocating some resources to nurture this expansion while optimizing our domestic operations.
*   **Best-Case Scenario:** Reallocated marketing budgets accelerate European market penetration, establishing market leadership and diversifying our revenue streams significantly.
*   **Worst-Case Scenario:** Over-allocating resources to Europe might slightly stall domestic growth, potentially allowing local competitors to gain incremental market share.

### 2. McKinsey Format: 3 Strategic Horizons

**Horizon 1: Defend Core Business**
We should aim to gently tighten our collection protocols to secure liquidity without straining client relationships.

**Horizon 2: Accelerate Growth**
The European market expansion seems well-positioned to benefit from additional, carefully phased marketing investments.

**Horizon 3: Build the Future**
The $45K annual savings from cloud optimization could be thoughtfully reinvested into automation R&D, preparing us for long-term scalability.

### 3. Eisenhower Matrix Prioritization

| Status | Consolidated Priorities |
|---|---|
| **Do First (Urgent & Important)** | Address short-term debt ($5M) refinancing, gently improve collections |
| **Schedule (Important & Not Urgent)** | Plan European market budget shifts, evaluate automation R&D |
| **Delegate (Urgent & Not Important)** | Routine supply chain cost reviews, daily KPI tracking |
| **Eliminate (Not Urgent & Not Important)** | Outdated low-ROI campaigns, redundant meetings |

### Executive Summary and Next Steps
By balancing the CFO's focus on preserving cash with the CEO's vision for European growth, we can achieve sustainable progress. A collaborative approach—funding the European expansion through gradual improvements in domestic collections—appears to be the most balanced path forward."""

        executive_summary = {
            "markdown_content": mock_markdown,
            "EXECUTIVE_METRICS": {
                "financial_health_score": 7.8,
                "altman_z_score": {"value": 2.85, "zone": "SAFE"},
                "cash_runway_months": 16.5,
                "return_on_equity_pct": 22.4
            },
            "RATIO_ANALYTICS": {
                "current_ratio": 2.15,
                "quick_ratio": 1.45,
                "debt_to_equity_ratio": 0.55,
                "net_profit_margin_pct": 14.2
            },
            "DUPONT_PILLARS": {
                "dupont_net_profit_margin": 0.142,
                "dupont_asset_turnover": 0.85,
                "dupont_equity_multiplier": 1.85
            },
            "BUDGET_SIMULATIONS_FORECASTS": {
                "forecasted_cash_flow_standard": [120000, 125000, 130000, 128000, 135000, 140000, 145000, 150000, 155000, 160000, 165000, 170000],
                "forecasted_cash_flow_recession": [120000, 115000, 110000, 105000, 100000, 95000, 90000, 85000, 82000, 80000, 78000, 75000],
                "cost_cutting_savings": {
                    "5_pct_plan": 45000,
                    "15_pct_plan": 135000,
                    "30_pct_plan": 270000
                }
            },
            "STRATEGIC_NARRATIVE": {
                "red_flags": [
                    "Receivables DSO increased by 15 days, locking up $12M in cash.",
                    "Supply chain costs have increased by 8% YTD.",
                    "Short-term debt maturity profile poses a mild liquidity risk in Q3."
                ],
                "green_flags": [
                    "Marketing ROI increased by 12% following Q1 campaign adjustments.",
                    "Cloud infrastructure optimization saved $45K annually.",
                    "New European market expansion showing 22% quarter-over-quarter growth."
                ],
                "action_plan": [
                    "Implement aggressive collections protocol to reduce DSO by 10 days before Q4.",
                    "Refinance $5M of short-term debt into long-term facilities to improve Q3 liquidity.",
                    "Double down on EU marketing spend while capping domestic OPEX."
                ]
            }
        }
        self.memory.set("executive_summary", executive_summary)
        
        # 5. Pass to UI/UX Agent
        ui_agent = self.sub_agents.get("ui_ux_agent")
        if ui_agent:
            self.memory.add_log(f"[{self.name}] Passing consolidated dataset to UI/UX Agent...")
            ui_agent.process(self.memory)
            
        return executive_summary

