        """TR analiz üret. Motor başarısız olursa statik fallback."""
        result = self.ai_engine.call(YENI_SYSTEM_PROMPT, f"{YENI_USER_KOMUTUM}\n\n{prompt}")
        if result:
            return result
        logging.warning("[CEO Agent] AI motoru yanıt vermedi, statik şablon kullanılıyor.")
        return STATIC_FALLBACK_TR

    def _translate_to_english(self, tr_markdown: str) -> str:
        """TR analizi EN'e çevir. Başarısız olursa statik EN fallback."""
        system = (
            "You are a professional financial translator. "
            "Translate Turkish financial executive summaries to English. "
            "Preserve all markdown formatting exactly (###, **, tables, lists). "
            "Output ONLY the translated markdown with no preamble."
        )
        user = f"Translate to professional English:\n\n{tr_markdown}"
        result = self.ai_engine.call(system, user)
        if result:
            return result
        logging.warning("[CEO Agent] EN çeviri başarısız, statik EN şablon kullanılıyor.")
        return STATIC_FALLBACK_EN

