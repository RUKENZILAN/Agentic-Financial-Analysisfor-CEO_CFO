class AIEngine:
    """Seçilen AI motorunu yönetir: Ollama, Gemini veya Claude."""

    def __init__(self, engine: str, api_key: str = None,
                 ollama_url: str = "http://localhost:11434",
                 ollama_model: str = "llama3:latest",
                 gemini_model: str = "gemini-1.5-flash",
                 claude_model: str = "claude-sonnet-4-6"):
        self.engine = engine.lower()
        self.api_key = api_key
        self.ollama_url = ollama_url.rstrip("/")
        self.ollama_model = ollama_model
        self.gemini_model = gemini_model
        self.claude_model = claude_model

    def call(self, system_prompt: str, user_prompt: str) -> str | None:
        """Seçilen motora istek gönder. None dönerse fallback kullanılır."""
        if self.engine == "ollama":
            return self._call_ollama(system_prompt, user_prompt)
        elif self.engine == "gemini":
            return self._call_gemini(system_prompt, user_prompt)
        elif self.engine == "claude":
            return self._call_claude(system_prompt, user_prompt)
        return None

    def _call_ollama(self, system_prompt, user_prompt):
        url = f"{self.ollama_url}/api/chat"
        payload = {
            "model": self.ollama_model,
            "messages": [
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt}
            ],
            "stream": False
        }
        try:
            req = urllib.request.Request(
                url,
                data=json.dumps(payload).encode("utf-8"),
                headers={"Content-Type": "application/json"}
            )
            with urllib.request.urlopen(req, timeout=60) as resp:
                return json.loads(resp.read().decode("utf-8"))["message"]["content"]
        except Exception as e:
            logging.warning(f"[Ollama] Bağlantı hatası: {e}")
            return None

    def _call_gemini(self, system_prompt, user_prompt):
        url = f"https://generativelanguage.googleapis.com/v1beta/models/{self.gemini_model}:generateContent?key={self.api_key}"
        payload = {
            "contents": [{"parts": [{"text": f"{system_prompt}\n\n{user_prompt}"}]}]
        }
        try:
            req = urllib.request.Request(
                url,
                data=json.dumps(payload).encode("utf-8"),
                headers={"Content-Type": "application/json"}
            )
            with urllib.request.urlopen(req, timeout=60) as resp:
                data = json.loads(resp.read().decode("utf-8"))
                return data["candidates"][0]["content"]["parts"][0]["text"]
        except Exception as e:
            logging.warning(f"[Gemini] API hatası: {e}")
            return None

    def _call_claude(self, system_prompt, user_prompt):
        url = "https://api.anthropic.com/v1/messages"
        payload = {
            "model": self.claude_model,
            "max_tokens": 2000,
            "system": system_prompt,
            "messages": [{"role": "user", "content": user_prompt}]
        }
        try:
            req = urllib.request.Request(
                url,
                data=json.dumps(payload).encode("utf-8"),
                headers={
                    "Content-Type": "application/json",
                    "x-api-key": self.api_key,
                    "anthropic-version": "2023-06-01"
                }
            )
            with urllib.request.urlopen(req, timeout=60) as resp:
                data = json.loads(resp.read().decode("utf-8"))
                return data["content"][0]["text"]
        except Exception as e:
            logging.warning(f"[Claude] API hatası: {e}")
            return None


