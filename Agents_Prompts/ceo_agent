)


class CentralMemory:
    def __init__(self):
        self.data = {}

    def set(self, key, value):
        self.data[key] = value

    def get(self, key, default=None):
        return self.data.get(key, default)

    def add_log(self, message):
        print(message)


class CEOAgent:
    def __init__(self, memory, sub_agents):
        self.name = "CEO_Agent"
        self.memory = memory
        self.sub_agents = sub_agents
        self.ollama_url = "http://localhost:11434"
        self.ollama_model = "llama3:latest"
        self.request_timeout = 120
        self.max_retries = 3
        self.output_language = "tr"  # "tr" veya "en"

    def _check_ollama_health(self):
        try:
            req = urllib.request.Request(
                f"{self.ollama_url}/api/tags", method='GET')
            with urllib.request.urlopen(req, timeout=5) as response:
                data = json.loads(response.read().decode('utf-8'))
                available_models = [m.get('name', '')
                                    for m in data.get('models', [])]
                logging.info(
                    f"Ollama motoru aktif. Mevcut modeller: {available_models}")

                for model_name in available_models:
                    if self.ollama_model.split(':')[0] in model_name:
                        self.ollama_model = model_name
                        logging.info(
                            f"Model bulundu ve secildi: {self.ollama_model}")
                        return True

                if not available_models:
                    logging.error(
                        "Ollama'da HIC model yuklu degil! 'ollama pull llama3' calistirin.")
                    return False

                logging.warning(
                    f"'{self.ollama_model}' bulunamadi. Ilk model kullanilacak: {available_models[0]}")
                self.ollama_model = available_models[0]
                return True

        except socket.timeout:
            logging.error(
                "Ollama yanit vermiyor (timeout). 'ollama serve' calisiyor mu?")
            return False
        except urllib.error.URLError as e:
            logging.error(
                f"Ollama'ya baglanilamiyor ({e.reason}). 'ollama serve' komutunu calistirdiniz mi?")
            return False
        except Exception as e:
            logging.error(f"Ollama saglik kontrolu basarisiz: {e}")
            return False

    def _call_local_ollama(self, prompt):
        url = f"{self.ollama_url}/api/chat"
        
        # Dile göre prompt seç
        if self.output_language == "tr":
            system_msg = YENI_SYSTEM_PROMPT
            user_msg = YENI_USER_KOMUTUM
        else:
            system_msg = (
                "You are a top-tier AI financial analyst serving as the CEO of a "
                "corporate financial intelligence unit. Your task is to analyze "
                "the compiled findings from sub-agents and produce a structured "
                "Executive Summary in English."
            )
            user_msg = "Analyze the following sub-agent findings and generate a comprehensive executive summary:"

        payload = {
            "model": self.ollama_model,
            "messages": [
                {"role": "system", "content": system_msg},
                {"role": "user", "content": f"{user_msg}\n\n{prompt}"}
            ],
            "stream": False,
            "options": {
                "temperature": 0.3,
                "num_predict": 2048
            }
        }

        for attempt in range(1, self.max_retries + 1):
            try:
                logging.info(
                    f"Ollama istegi gonderiliyor (Deneme {attempt}/{self.max_retries})...")
                data = json.dumps(payload).encode('utf-8')
                req = urllib.request.Request(
                    url, data=data, headers={'Content-Type': 'application/json'})

                with urllib.request.urlopen(req, timeout=self.request_timeout) as response:
                    res = json.loads(response.read().decode('utf-8'))
                    content = res.get('message', {}).get('content', '')
                    if content and len(content) > 50:
                        logging.info(
                            f"Ollama yanit verdi ({len(content)} karakter)")
                        return content
                    else:
                        logging.warning(
                            f"Ollama bos/kisa yanit dondu (Deneme {attempt})")
            except socket.timeout:
                logging.error(
                    f"Timeout (Deneme {attempt}/{self.max_retries}) - Model cok yavas veya donmus olabilir")
            except urllib.error.URLError as e:
                logging.error(
                    f"Baglanti hatasi (Deneme {attempt}): {e.reason}")
            except Exception as e:
                logging.error(
                    f"Beklenmeyen hata (Deneme {attempt}): {e}")

            if attempt < self.max_retries:
                wait_time = 2 ** attempt
                logging.info(f"{wait_time} saniye bekleniyor...")
                time.sleep(wait_time)

        logging.error(
            "Tum denemeler basarisiz. Fallback summary moduna geciliyor.")
        return None

    # ============================================================
    # 🎯 FALLBACK: ARTIK SADECE TÜRKÇE
    # ============================================================
