- {optimizer.get('Cost Savings', 'Pazarlama bütçesinde %15 tasarruf potansiyeli tespit edildi.')}

---

## 6. Stratejik Öneriler
1. **Maliyet Disiplini**: {optimizer.get('Optimization Strategy', 'Sıfır tabanlı bütçeleme metodolojisine geçiş.')}
2. **Operasyonel Verimlilik**: {optimizer.get('Resource Allocation', "Eski BT altyapısından bulut altyapısına geçiş.")}
3. **Risk Yönetimi**: {forecaster.get('Altman Z-Score', 'Z-Skoru güvenli bölgede, ancak tedarik zinciri çeşitlendirmesi önerilir.')}

---

> ⚠️ **Sistem Notu**: Bu özet, yerel LLM (Ollama/Llama 3) motoru yanıt vermediği için alt ajanların yapılandırılmış verilerinden **otomatik olarak konsolide edilmiştir**. Tam doğal dil sentezi için `ollama serve` komutunun çalıştığından emin olun.
"""
        return fallback_md

    def run(self):
        logging.info("=" * 60)
        logging.info("[CEO Agent] Coklu Ajan Pipeline Baslatiliyor")
        logging.info("=" * 60)

        try:
            for agent in self.sub_agents:
                logging.info(f">> {agent.name} calistiriliyor...")
                agent.process(self.memory)
        except Exception as e:
            logging.warning(f"Alt ajanlar calisirken sorun: {e}")

        findings = self.memory.get("sub_agent_findings", {})
        compiled_prompt = json.dumps(findings, indent=2, ensure_ascii=False)

        logging.info("-" * 60)
        ollama_alive = self._check_ollama_health()
        logging.info("-" * 60)

        ai_markdown_analysis = None
        if ollama_alive:
            ai_markdown_analysis = self._call_local_ollama(compiled_prompt)

        if not ai_markdown_analysis:
            logging.warning(
                "Fallback summary moduna geciliyor (Türkçe konsolidasyon)")
            ai_markdown_analysis = self._generate_fallback_summary(findings)

        forecaster_data = findings.get("Forecaster & Risk Agent", {})
        optimizer_data = findings.get("Optimizer Agent", {})

        def to_list(value, default):
            if not value:
                return [default]
            return value if isinstance(value, list) else [str(value)]

        critical_risks = to_list(
            forecaster_data.get("Key Risks"),
            "Tedarik zinciri kesintileri Q4 operasyonları etkileyebilir."
        )
        growth_opportunities = to_list(
            optimizer_data.get("Cost Savings"),
            "Pazarlama bütçesinde %15 optimizasyon potansiyeli tespit edildi."
        )
        strategic_action_plan = to_list(
            optimizer_data.get("Optimization Strategy"),
            "Önümüzdeki çeyrek için sıfır tabanlı bütçeleme uygulayın."
        )

        confidentiality_en = forecaster_data.get(
            "Confidentiality Rate", "95% (Highly Restricted - Boardroom Only)")
        confidence_en = forecaster_data.get(
            "Forecast Confidence Rate", "88% (3-Year Historical Baseline)")

        final_js_object = {
            "markdown_content": ai_markdown_analysis,
            "critical_risks": critical_risks,
            "growth_opportunities": growth_opportunities,
            "strategic_action_plan": strategic_action_plan,
            "confidentiality_rate_en": confidentiality_en,
            "forecast_confidence_rate_en": confidence_en,
            "confidentiality_rate_tr": "95% (Çok Gizli - Sadece Yönetim Kurulu / Kurum İçi Finansal Veri)",
            "forecast_confidence_rate_tr": "88% (Normal piyasa koşulları altındaki 3 yıllık geçmiş veriye dayalı güven oranı)",
            "EXECUTIVE_METRICS": {
                "financial_health_score": 7.8,
                "altman_z_score": {"value": 2.85, "zone": "SAFE"},
                "cash_runway_months": 16.5,
                "return_on_equity_pct": 22.4
            },
            "RATIO_ANALYTICS": {
                "current_ratio": 2.15,
                "quick_ratio": 1.45,
                "debt_to_equity_ratio": 0.55,
                "net_profit_margin_pct": 14.2
            },
            "DUPONT_PILLARS": {
                "dupont_net_profit_margin": 0.142,
                "dupont_asset_turnover": 0.85,
                "dupont_equity_multiplier": 1.85
            },
            "BUDGET_SIMULATIONS_FORECASTS": {
                "forecasted_cash_flow_standard": [120000, 125000, 130000, 128000, 135000, 140000, 145000, 150000, 155000, 160000, 165000, 170000],
                "forecasted_cash_flow_recession": [120000, 115000, 110000, 105000, 100000, 95000, 90000, 88000, 85000, 83000, 80000, 78000],
                "cost_cutting_savings": {
                    "marketing_spend_reduction": "$15,000",
                    "software_redundancy_cleanup": "$12,000",
                    "cloud_infrastructure_migration": "Optimized"
                }
            }
        }

        output_path = os.path.join(
            os.path.dirname(os.path.abspath(__file__)), "dashboard_data.js")
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(
                f"const dashboardData = {json.dumps(final_js_object, indent=2, ensure_ascii=False)};")

        logging.info("=" * 60)
        logging.info("[CEO Agent] dashboard_data.js basariyla guncellendi!")
        logging.info(
            f"Executive Summary uzunlugu: {len(ai_markdown_analysis)} karakter")
        logging.info(f"Output dili: {self.output_language}")
        logging.info("=" * 60)


