def resolve_engine_config() -> dict:
    """
    Motor seçimini şu öncelik sırasına göre çöz:
    1. Komut satırı argümanları  (--engine, --api-key)
    2. Kaydedilmiş config dosyası (ai_config.json)
    3. İnteraktif seçim menüsü
    """
    # 1. CLI argümanları
    if args.engine:
        logging.info(f"[Config] Motor CLI'dan alındı: {args.engine}")
        return {"engine": args.engine, "api_key": args.api_key}

    # 2. Kayıtlı config
    cfg = load_config()
    if cfg.get("engine"):
        logging.info(f"[Config] Motor kayıtlı configden yüklendi: {cfg['engine']}")
        return cfg

    # 3. İnteraktif menü
    return prompt_engine_selection()


