import logging
from base_agent import BaseAgent

class AuditorAgent(BaseAgent):
    """
    Role: Financial Auditor Agent
    """
    def __init__(self):
        super().__init__(
            name="Auditor Agent",
            system_prompt="""Context: You are the Auditor Agent within the Antigravity Multi-Agent system. Your job is to ensure the integrity, accuracy, and compliance of the financial data provided by the CEO Agent.

Instructions:
1. Review the structured financial data (Trial Balances, Balance Sheets, Income Statements).
2. Perform discrepancy checks (e.g., ensuring Assets = Liabilities + Equity).
3. Flag any potential accounting errors, compliance risks, or unusual transactions.
4. Prepare an audit report detailing any issues found.
5. Return your findings to the Central Memory for the CEO Agent to consolidate.
"""
        )

    def process(self, memory):
        self.log_start(memory)
        
        findings = memory.get("sub_agent_findings", {})
        findings[self.name] = {
            "Equation Check": "Passed (Assets = Liabilities + Equity)",
            "Discrepancies": "None detected in trial balance",
            "Compliance Risks": "Minor compliance risk regarding recent tax code changes",
            "Unusual Transactions": "No significant unusual transactions flagged"
        }
        memory.set("sub_agent_findings", findings)
        
        self.log_end(memory)

if __name__ == "__main__":
    from ceo_agent import CentralMemory
    logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
    
    memory = CentralMemory()
    agent = AuditorAgent()
    agent.process(memory)
